{
  "name": "x-downloader-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3025",
    "dev:cf": "opennextjs-cloudflare dev --port 3025",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare deploy",
    "types:worker": "wrangler types",
    "migrate:d1": "wrangler d1 migrations apply x-downloader --remote",
    "migrate:d1:local": "wrangler d1 migrations apply x-downloader --local",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.9.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.57.1"
  }
}
